{
  "name": "mimic-dice",
  "version": "0.1.0",
  "private": true,
  "description": "Mimic Dice web app scaffold ready to evolve into an Electron desktop app.",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cache:bestiary-images": "powershell -ExecutionPolicy Bypass -File scripts/cache-bestiary-images.ps1",
    "cache:item-images": "powershell -ExecutionPolicy Bypass -File scripts/cache-item-images.ps1",
    "electron": "electron .",
    "electron:dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:portable": "npm run build && electron-builder --win portable"
  },
  "keywords": [
    "dice",
    "game",
    "vite",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12",
    "vite": "^7.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.mimicdice.app",
    "productName": "Mimic Dice",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.ico",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "Mimic-Dice-portable-${version}-${arch}.exe"
    }
  }
}
